{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/uploads/(.*)", "dest": "server.js" },
    { "src": "/dashboard", "dest": "/public/applicant.html" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/scan", "dest": "/public/scanner.html" },
    { "src": "/verify-certificate.html", "dest": "/public/verify-certificate.html" },
    { "src": "/judge.html", "dest": "/public/judge.html" },
    { "src": "/admin-live-scanner.html", "dest": "/public/admin-live-scanner.html" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/downloads/(.*)", "dest": "/public/downloads/$1" },
    { "src": "/scanner-download", "dest": "/public/scanner-download.html" },
    { "src": "/(.*\\.(png|jpg|jpeg|gif|webp|svg|ico|apk|woff2?|webmanifest))", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/pending-registration-reminders",
      "schedule": "0 10 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

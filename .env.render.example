# Copy to Render Dashboard → autism-portal → Environment
# ZeptoMail keys are also editable in Admin → Integrations (stored in DB).

# ── Required ──────────────────────────────────────────────
NODE_ENV=production
# DATABASE_URL — paste your REAL string in Render Dashboard (do not use a placeholder):
# Neon: Console → Connect → Pooled connection → copy full postgresql://…?sslmode=require
# DATABASE_URL=postgresql://neondb_owner:npg_6hitr5UIxosF@ep-misty-meadow-aphijqi6-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
PUBLIC_BASE_URL=https://autism.vaidyagogate.org
APPLICANT_HOST=autism.vaidyagogate.org
MAIN_SITE_URL=https://autism.vaidyagogate.org
PORTAL_SCHEME=https

# ── Email (ZeptoMail) ───────────────────────────────────
ZEPTOMAIL_API_KEY=
ZEPTO_FROM=care@vaidyagogate.org
ZEPTO_FROM_NAME=Vaidya Gogate Memorial Foundation
ZEPTOMAIL_REGION=in

# ── Bootstrap admin (first deploy only) ─────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Cron (must match render.yaml CRON_SECRET) ───────────
# External keepalive: ping https://autism.vaidyagogate.org/api/ping every 10–14 min (cron-job.org)
CRON_SECRET=

# ── WhatsApp (optional) ─────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en

# ── Payments (optional) ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_VERSION=2023-08-01
PAYTM_MID=
PAYTM_MERCHANT_KEY=

# ── File storage R2 (optional — larger uploads) ─────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── AI health assistant (optional) ──────────────────────
OPENAI_API_KEY=

# ── OTP / auth policy ───────────────────────────────────
OTP_DIGITS=4
OTP_TTL_MINUTES=10
REQUIRE_SIGNUP_OTP=1
REQUIRE_LOGIN_OTP=0
OTP_RETURN_CODE=0

# ── Misc ────────────────────────────────────────────────
ADMIN_CONTACT_EMAIL=info@vaidyagogate.org
CHECKIN_TIMEZONE=Asia/Kolkata
DISABLE_DEMO_ACCOUNTS=0

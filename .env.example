# Autism portal — local dev or copy keys to Render Dashboard
# Full Render list: .env.render.example

NODE_ENV=development
PORT=3001
PORTAL_SCHEME=http

APPLICANT_HOST=autism.vaidyagogate.org
PUBLIC_BASE_URL=https://autism.vaidyagogate.org
MAIN_SITE_URL=https://autism.vaidyagogate.org

# PostgreSQL (required in production on Render)
# DATABASE_URL=postgresql://user:pass@host:5432/autism_portal

# ZeptoMail
# ZEPTOMAIL_API_KEY=
# ZEPTO_FROM=care@vaidyagogate.org
# ZEPTO_FROM_NAME=Vaidya Gogate Memorial Foundation
# ZEPTOMAIL_REGION=in

# Cron (Render cron jobs + optional external ping)
# CRON_SECRET=change-me-long-random

# Bootstrap admin (first deploy)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
